# Aether — Local environment variables
# Copy this file to .env and fill in values. Never commit .env.

# PostgreSQL
POSTGRES_DB=aethergrid
POSTGRES_USER=aether
POSTGRES_PASSWORD=

# Redis (no auth by default for local dev)
# REDIS_PASSWORD=

# Kafka
# KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Ollama
# OLLAMA_MODEL=gemma2:2b
# OLLAMA_EMBEDDING_MODEL=all-minilm

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=

# Application
# JWT_ISSUER=http://localhost:9000
# JWT_SECRET=
